# prod namespace — Docker-simulated for now, same local server as dev.
# When Temporal Cloud is purchased, update TEMPORAL_ADDRESS to the Cloud gRPC
# endpoint (<namespace>.<account>.tmprl.cloud:7233) and uncomment+fill in either
# TEMPORAL_API_KEY or the TEMPORAL_TLS_CLIENT_CERT_*/TEMPORAL_TLS_CLIENT_KEY_*
# pair. No code changes required — these are read as-is by
# @temporalio/envconfig's loadClientConnectConfig() (src/core/connection-client.ts,
# src/core/connection-worker.ts).
TEMPORAL_NAMESPACE=prod
TEMPORAL_ADDRESS=localhost:17233

# Leave these fully unset (commented out) rather than blank — envconfig treats
# an empty-but-set value as present and tries to use it (e.g. as a file path).
# TEMPORAL_API_KEY=
# TEMPORAL_TLS_CLIENT_CERT_PATH=
# TEMPORAL_TLS_CLIENT_KEY_PATH=
