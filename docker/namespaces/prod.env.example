# prod namespace — Docker-simulated for now, same local server as dev.
# When Temporal Cloud is purchased, update TEMPORAL_ADDRESS to the Cloud gRPC
# endpoint (<namespace>.<account>.tmprl.cloud:7233) and fill in either the
# mTLS cert/key pair or TEMPORAL_CLOUD_API_KEY. No code changes required —
# src/config/env.ts reads these values as-is.
TEMPORAL_NAMESPACE=prod
TEMPORAL_ADDRESS=localhost:17233

TEMPORAL_TLS_CERT_PATH=
TEMPORAL_TLS_KEY_PATH=
TEMPORAL_CLOUD_API_KEY=
