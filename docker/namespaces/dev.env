# dev namespace — local Docker only today
# Read by @temporalio/envconfig's loadClientConnectConfig() — see src/core/connection-client.ts
# and src/core/connection-worker.ts. Same variable names work unchanged against Temporal Cloud
# (see prod.env.example): set TEMPORAL_ADDRESS to the Cloud gRPC endpoint and either
# TEMPORAL_API_KEY or the TEMPORAL_TLS_CLIENT_CERT_*/TEMPORAL_TLS_CLIENT_KEY_* pair.
TEMPORAL_NAMESPACE=dev
TEMPORAL_ADDRESS=localhost:17233

# TLS / Temporal Cloud fields — leave commented out locally. envconfig treats an
# empty-but-set value (e.g. `TEMPORAL_API_KEY=`) as present and tries to use it,
# so these must be fully unset rather than blank.
# TEMPORAL_API_KEY=
# TEMPORAL_TLS_CLIENT_CERT_PATH=
# TEMPORAL_TLS_CLIENT_KEY_PATH=
