{
  "name": "@chg/temporal-platform",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./workflow": {
      "require": "./dist/core/workflow-exports.js",
      "default": "./dist/core/workflow-exports.js",
      "types": "./dist/core/workflow-exports.d.ts"
    },
    "./testing": {
      "require": "./dist/core/testing.js",
      "default": "./dist/core/testing.js",
      "types": "./dist/core/testing.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:workflow-bundle": "ts-node scripts/build-workflow-bundle.ts",
    "lint": "eslint . --ext .ts",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "worker": "ts-node src/worker/worker.ts",
    "worker:prod": "node dist/worker/worker.js",
    "start:workflow": "ts-node src/client/start-workflow.ts",
    "webhook": "ts-node src/core/webhook-server.ts"
  },
  "peerDependencies": {
    "@temporalio/worker": "1.18.1"
  },
  "dependencies": {
    "@temporalio/activity": "1.18.1",
    "@temporalio/client": "1.18.1",
    "@temporalio/envconfig": "1.18.1",
    "@temporalio/proto": "1.18.1",
    "@temporalio/workflow": "1.18.1",
    "deepmerge-ts": "^7.1.5",
    "dotenv": "^17.4.2",
    "effect": "3.21.4",
    "express": "^5.2.1",
    "helmet": "^8.2.0"
  },
  "devDependencies": {
    "@temporalio/testing": "1.18.1",
    "@temporalio/worker": "1.18.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.1",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
